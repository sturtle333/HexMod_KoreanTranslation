    // === Patchi stuff! ===
    
    
    landing: "아무래도 나는 새로운 마법적인 기예에 다가가는 방법을 찾아낸 것 같다. 육각형 모양 격자에 요상하고 투박한 패턴을 그려넣어 마법을 이끌어낼 수 있다고 한다. \
      이것은 나에게 정말 매혹적으로 다가온다. 그래서 나는 내 모든 생각과 발견을 여기에 적어두려고 한다.\
      $(br2)$(l:https://forum.petra-k.at/index.php)포럼 링크/$",
    
    category: {
      basics: {
        "": "시작하기",
        desc: "이 기예의 전문가들은 $(l:items/staff)$(item)지팡이/$로 허공에 패턴을 그려 소위 _마법 이라고 부르는 것을 시전하는 것 같다. -- \
          혹은 마법을 시전하기 위해서 $(l:items/hexcasting)$(item)강력한 마법 도구/$를 제작하기도 한다. \
          이걸 따라하려면 어떻게 해야할까?",
      },
      casting: {
        "": "마법 시전",
        desc: "이제 그 늙은 전문가들이 _마법 을 어떻게 사용하는지 이해가 되는 것 같다! 조금 복잡하긴 하다만, \
          조금만 더 조사하면 분명 무언가를 알아낼 것만 같다. 조금만 더 조사하면...",
      },
      items: {
        "": "도구",
        desc: "이곳에는 내가 마법을 연구하면서 발견한 마법스럽고 신비로운 도구를 정리해두었다.",
      },
      
      greatwork: {
        "": "The Great Work",
        desc: "I have seen... so much. I have... experienced... annihilation and deconstruction and reconstruction. \
          I have seen the atoms of the world screaming as they were inverted and subverted and demoted to energy. \
          I have seen I have seen I have s$(k)get stick bugged lmao/$",
        // alwinfy you think you're so funny
      },
      
      lore: {
        "": "세계관",
        desc: "내 연구와는 직접적인 관련이 없는 편지와 문자들을 발견하였다. \
          하지만 이 세계의 역사 단편을 연구한다면, 분명 신성하고 흥미로운 사실을 발견할 것 같다. 한 번 살펴보도록 하자...",
      },
      
      interop: {
        "": "타 모드 호환성",
        desc: "Hex Casting과 호환되는 몇 가지 모드를 설치하신 것 같군요! 여기에 자세한 설명을 적어두도록 하겠습니다.",
      },
      
      patterns: {
        "": "패턴",
        desc: "내가 발견한 모든 패턴과 패턴의 행동에 대한 목록.",
      },
      spells: {
        "": "주문",
        desc: "패턴이 이 세계에 일으킬 수 있는 마법적인 효과들.",
      },
      great_spells: {
        "": "위대한 주문",
        desc: "이곳에 나열된 주문들은 전설적인 힘과 난이도를 가지고 있다고 알려져있다. \
          이 주문들은 아주 $(l:items/scroll)드물게/$ 기록되어 있다. (문헌에 따르면 그럴만한 이유가 있다고 한다.) \
          아마 진작에 멸종해버린 전통주의자들의 궤변 때문일 것이다. 패턴은 그저 패턴일 뿐.$(br2)\
          뭐... 설마 잘못되기라도 할까?",
      },
    },
    // ^ categories
    
